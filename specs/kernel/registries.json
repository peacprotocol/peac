{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "0.5.0",
  "description": "PEAC protocol registries: payment rails, control engines, transport methods, agent protocols, proof types, extension keys, pillar values",
  "payment_rails": [
    {
      "id": "x402",
