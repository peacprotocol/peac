  "pillar_values": {
    "_comment": "CLOSED vocabulary. Unknown values MUST be rejected with invalid_pillar_value. Values MUST be unique and alphabetically sorted in receipt arrays.",
    "values": [
      "access",
      "attribution",
      "commerce",
      "compliance",
      "consent",
      "identity",
      "privacy",
      "provenance",
      "purpose",
      "safety"
    ]
