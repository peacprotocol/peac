    },
    {
      "name": "ucp-embed-at-limit",
      "description": "UCP embed carrier at exactly 64 KB (65536 bytes)",
      "type": "carrier-boundary",
      "primary_requirement_id": "CARRIER-MCP-001",
      "requirement_ids": ["CARRIER-MCP-001"],
      "status": "boundary",
      "input": {
        "transport": "ucp",
        "format": "embed",
        "jws_byte_length": 65536
      },
      "expected": {
        "valid": true,
        "encoded_byte_length": 65536
      }
    },
    {
      "name": "utf8-multibyte-at-boundary",
      "description": "UTF-8 multi-byte characters at boundary do not cause off-by-one",
      "type": "carrier-boundary",
      "primary_requirement_id": "CARRIER-MCP-001",
      "requirement_ids": ["CARRIER-MCP-001"],
      "status": "boundary",
      "input": {
        "transport": "mcp",
        "format": "embed",
        "jws_byte_length": 65534,
        "note": "2 bytes under limit to verify byte-level (not char-level) measurement"
      },
      "expected": {
        "valid": true,
        "encoded_byte_length": 65534
      }
    }
  ]
}
