{
  "$comment": "Invalid ActorBinding fixtures (DD-142, DD-143, DD-144, v0.11.3+)",
  "version": "0.11.3",
  "fixtures": [
    {
      "name": "invalid-origin-with-path",
      "description": "Origin MUST be origin-only (scheme + host + optional port); path is rejected",
      "input": {
        "id": "agent:bad-origin-001",
        "proof_type": "ed25519-cert-chain",
        "origin": "https://example.com/api/v1"
      },
      "expected": {
        "valid": false,
        "error_contains": "origin must be an origin-only URL"
      }
    },
    {
      "name": "invalid-origin-with-query",
      "description": "Origin MUST NOT contain query parameters",
      "input": {
        "id": "agent:bad-origin-002",
        "proof_type": "ed25519-cert-chain",
        "origin": "https://example.com?token=abc"
      },
      "expected": {
        "valid": false,
        "error_contains": "origin must be an origin-only URL"
      }
    },
    {
      "name": "invalid-origin-with-fragment",
      "description": "Origin MUST NOT contain fragment",
      "input": {
        "id": "agent:bad-origin-003",
        "proof_type": "ed25519-cert-chain",
        "origin": "https://example.com#section"
      },
      "expected": {
        "valid": false,
        "error_contains": "origin must be an origin-only URL"
      }
    },
    {
      "name": "invalid-mvis-missing-key-binding",
      "description": "MVIS requires all 5 fields; missing key_binding is rejected (E_MVIS_INCOMPLETE)",
      "input_mvis": {
        "issuer": "https://issuer.example.com",
        "subject": "agent:test-001",
        "time_bounds": {
          "not_before": "2026-01-01T00:00:00Z",
          "not_after": "2026-12-31T23:59:59Z"
        },
        "replay_protection": {
          "jti": "unique-token-id-001"
        }
      },
      "expected": {
        "valid": false,
        "error_contains": "key_binding"
      }
    },
    {
      "name": "invalid-mvis-missing-subject",
      "description": "MVIS requires subject field",
      "input_mvis": {
        "issuer": "https://issuer.example.com",
        "key_binding": "kid:key-2026-01",
        "time_bounds": {
          "not_before": "2026-01-01T00:00:00Z",
          "not_after": "2026-12-31T23:59:59Z"
        },
        "replay_protection": {
          "jti": "unique-token-id-002"
        }
      },
      "expected": {
        "valid": false,
        "error_contains": "subject"
      }
    },
    {
      "name": "invalid-mvis-time-bounds-reversed",
      "description": "MVIS time_bounds: not_before must be before not_after",
      "input_mvis": {
        "issuer": "https://issuer.example.com",
        "subject": "agent:test-002",
        "key_binding": "kid:key-2026-01",
        "time_bounds": {
          "not_before": "2026-12-31T23:59:59Z",
          "not_after": "2026-01-01T00:00:00Z"
        },
        "replay_protection": {
          "jti": "unique-token-id-003"
        }
      },
      "expected": {
        "valid": false,
        "error_contains": "not_before must be before not_after"
      }
    },
    {
      "name": "invalid-unknown-proof-type",
      "description": "Unknown proof_type is rejected (not in DD-143 vocabulary)",
      "input": {
        "id": "agent:bad-proof-001",
        "proof_type": "unknown-method",
        "origin": "https://example.com"
      },
      "expected": {
        "valid": false,
        "error_contains": "proof_type"
      }
    },
    {
      "name": "invalid-intent-hash-format",
      "description": "intent_hash must match sha256:<64 hex chars>",
      "input": {
        "id": "agent:bad-hash-001",
        "proof_type": "ed25519-cert-chain",
        "origin": "https://example.com",
        "intent_hash": "md5:abc123"
      },
      "expected": {
        "valid": false,
        "error_contains": "intent_hash"
      }
    },
    {
      "name": "invalid-intent-hash-uppercase",
      "description": "intent_hash hex MUST be lowercase; uppercase is rejected",
      "input": {
        "id": "agent:bad-hash-002",
        "proof_type": "ed25519-cert-chain",
        "origin": "https://example.com",
        "intent_hash": "sha256:E3B0C44298FC1C149AFBF4C8996FB92427AE41E4649B934CA495991B7852B855"
      },
      "expected": {
        "valid": false,
        "error_contains": "intent_hash"
      }
    },
    {
      "name": "invalid-origin-trailing-dot",
      "description": "Origin MUST NOT have trailing dot in hostname (FQDN notation)",
      "input": {
        "id": "agent:bad-origin-004",
        "proof_type": "ed25519-cert-chain",
        "origin": "https://example.com."
      },
      "expected": {
        "valid": false,
        "error_contains": "origin must be an origin-only URL"
      }
    },
    {
      "name": "invalid-origin-userinfo",
      "description": "Origin MUST NOT contain userinfo (credential leak risk)",
      "input": {
        "id": "agent:bad-origin-005",
        "proof_type": "ed25519-cert-chain",
        "origin": "https://user:pass@example.com"
      },
      "expected": {
        "valid": false,
        "error_contains": "origin must be an origin-only URL"
      }
    },
    {
      "name": "invalid-mvis-absurd-duration",
      "description": "MVIS time_bounds duration must not exceed 100 years",
      "input_mvis": {
        "issuer": "https://issuer.example.com",
        "subject": "agent:test-003",
        "key_binding": "kid:key-2026-01",
        "time_bounds": {
          "not_before": "2026-01-01T00:00:00Z",
          "not_after": "2200-01-01T00:00:00Z"
        },
        "replay_protection": {
          "jti": "unique-token-id-004"
        }
      },
      "expected": {
        "valid": false,
        "error_contains": "100 years"
      }
    }
  ],
  "schema_version": "0.11.3"
}
