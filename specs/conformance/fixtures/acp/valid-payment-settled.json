      "reference": "pi_conf_02",
      "amount": 2500,
      "currency": "USD",
      "observed_payment_state": "settled"
    }
  },
  "expected": {
    "valid": true,
    "rail": "stripe",
    "amt": 2500,
    "cur": "USD",
    "has_commerce_event": true,
    "commerce_event": "settlement",
    "observed_payment_state": "settled"
  },
  "notes": "Explicit payment artifact with settled state produces commerce evidence with settlement event."
}
