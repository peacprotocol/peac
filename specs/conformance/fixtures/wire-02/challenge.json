      "requirement_ids": ["WIRE02-CHAL-002"],
      "status": "negative"
    },
    {
      "name": "challenge-all-7-types",
      "description": "All 7 challenge_type enum values are accepted",
      "type": "schema-validation",
      "input": {
        "challenge_types": [
          "payment_required",
          "identity_required",
          "consent_required",
          "attestation_required",
          "rate_limited",
          "purpose_disallowed",
          "custom"
