        "claims": {
          "peac_version": "0.2",
          "kind": "challenge",
          "type": "org.peacprotocol/access",
          "iss": "https://api.example.com",
          "iat": 1709500000,
          "jti": "chal-001",
          "extensions": {
            "org.peacprotocol/challenge": {
              "challenge_type": "payment_required",
              "problem": {
                "status": 402,
                "type": "https://api.example.com/problems/payment-required",
                "title": "Payment Required"
              }
            }
          }
        }
      },
      "expected": {
        "valid": true
      },
      "primary_requirement_id": "WIRE02-CHAL-002",
      "requirement_ids": ["WIRE02-CHAL-001", "WIRE02-CHAL-002", "WIRE02-CHAL-003"],
      "status": "positive"
    },
    {
      "name": "challenge-reject-missing-problem-type",
      "description": "Challenge problem.type is REQUIRED: omitting it MUST fail validation",
      "type": "schema-validation",
      "input": {
        "claims": {
          "peac_version": "0.2",
          "kind": "challenge",
          "type": "org.peacprotocol/access",
          "iss": "https://api.example.com",
          "iat": 1709500000,
          "jti": "chal-002",
          "extensions": {
            "org.peacprotocol/challenge": {
              "challenge_type": "payment_required",
              "problem": {
                "status": 402,
                "title": "Payment Required"
              }
            }
          }
        }
      },
      "expected": {
        "valid": false,
        "error_code": "E_INVALID_FORMAT"
