    {
      "name": "challenge-problem-with-rfc9457-passthrough",
      "description": "RFC 9457 problem object allows passthrough of extension members (Section 6.2)",
      "type": "schema-validation",
      "input": {
        "claims": {
          "peac_version": "0.2",
