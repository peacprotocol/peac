            "org.peacprotocol/challenge": {
              "challenge_type": "unknown_type",
              "problem": {
                "status": 403,
                "type": "https://api.example.com/problems/unknown"
              }
            }
          }
        }
      },
      "expected": {
        "valid": false,
        "error_code": "E_INVALID_FORMAT"
