{
  "$comment": "Wire 0.2 Identifier Stack and Token Confusion conformance vectors (Section 18)",
  "version": "0.12.0",
  "schema_version": "0.12.0",
  "fixtures": [
    {
      "name": "compact-typ-valid",
      "description": "Compact form typ interaction-record+jwt is accepted",
      "type": "full-pipeline",
      "primary_requirement_id": "WIRE02-IDENT-001",
      "requirement_ids": ["WIRE02-IDENT-001", "WIRE02-MEDIA-001"],
      "status": "positive",
      "input": {
        "claims": {
          "peac_version": "0.2",
          "kind": "evidence",
          "type": "org.peacprotocol/payment",
          "iss": "https://api.example.com",
          "iat": 1709500000,
          "jti": "ident-valid-001"
        }
      },
      "expected": {
        "valid": true
      }
    },
    {
      "name": "media-type-form-accepted",
      "description": "Full media-type form application/interaction-record+jwt is accepted",
      "type": "full-pipeline",
      "primary_requirement_id": "WIRE02-IDENT-002",
      "requirement_ids": ["WIRE02-IDENT-002", "WIRE02-MEDIA-002"],
      "status": "positive",
      "input": {
        "header_overrides": {
          "typ": "application/interaction-record+jwt"
        },
        "claims": {
          "peac_version": "0.2",
          "kind": "evidence",
          "type": "org.peacprotocol/payment",
          "iss": "https://api.example.com",
          "iat": 1709500000,
          "jti": "ident-valid-002"
        }
      },
      "expected": {
        "valid": true
      }
    },
    {
      "name": "reject-typ-with-parameters",
      "description": "typ with content-type parameters MUST NOT be parsed",
      "type": "jws-security",
      "primary_requirement_id": "WIRE02-IDENT-003",
      "requirement_ids": ["WIRE02-IDENT-003"],
      "status": "negative",
      "input": {
        "header_overrides": {
          "typ": "interaction-record+jwt; charset=utf-8"
        },
        "claims": {
          "peac_version": "0.2",
          "kind": "evidence",
          "type": "org.peacprotocol/payment",
          "iss": "https://api.example.com",
          "iat": 1709500000,
          "jti": "ident-invalid-001"
        }
      },
      "expected": {
        "valid": false,
        "error_code": "E_INVALID_FORMAT"
      }
    },
    {
      "name": "reject-typ-peac-version-mismatch",
      "description": "typ/peac_version mismatch produces E_WIRE_VERSION_MISMATCH",
      "type": "full-pipeline",
      "primary_requirement_id": "WIRE02-IDENT-004",
      "requirement_ids": ["WIRE02-IDENT-004", "WIRE02-MEDIA-005"],
      "status": "negative",
      "input": {
        "header_overrides": {
          "typ": "peac-receipt/0.1"
        },
        "claims": {
          "peac_version": "0.2",
          "kind": "evidence",
          "type": "org.peacprotocol/payment",
          "iss": "https://api.example.com",
          "iat": 1709500000,
          "jti": "ident-invalid-002"
        }
      },
      "expected": {
        "valid": false,
        "error_code": "E_WIRE_VERSION_MISMATCH"
      }
    },
    {
      "name": "reject-unknown-peac-version",
      "description": "Unknown peac_version value is rejected",
      "type": "full-pipeline",
      "primary_requirement_id": "WIRE02-IDENT-004",
      "requirement_ids": ["WIRE02-IDENT-004"],
      "status": "negative",
      "input": {
        "claims": {
          "peac_version": "1.0",
          "kind": "evidence",
          "type": "org.peacprotocol/payment",
          "iss": "https://api.example.com",
          "iat": 1709500000,
          "jti": "ident-invalid-003"
        }
      },
      "expected": {
        "valid": false,
        "error_code": "E_UNSUPPORTED_WIRE_VERSION"
      }
    }
  ]
}
