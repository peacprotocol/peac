    {
      "name": "unknown-extension-preserved-with-warning",
      "description": "Unknown but well-formed extension key preserved with warning",
      "type": "warning",
      "primary_requirement_id": "WIRE02-EXT-017",
      "requirement_ids": ["WIRE02-EXT-016", "WIRE02-EXT-017", "WIRE02-EXT-018"],
      "status": "positive",
      "input": {
        "claims": {
          "peac_version": "0.2",
          "kind": "evidence",
          "type": "org.peacprotocol/payment",
          "iss": "https://api.example.com",
          "iat": 1709500000,
          "jti": "ext-warn-001",
          "extensions": {
            "com.example/custom-data": {
              "key": "value"
            }
          }
        }
      },
      "expected": {
        "valid": true,
        "warnings": [
