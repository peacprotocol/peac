  "fixtures": [
    {
      "name": "commerce-extension-valid",
      "description": "Valid commerce extension with all required fields",
      "type": "full-pipeline",
      "primary_requirement_id": "WIRE02-EXT-006",
      "requirement_ids": ["WIRE02-EXT-006", "WIRE02-EXT-007", "WIRE02-EXT-008", "WIRE02-EXT-001"],
      "status": "positive",
      "input": {
        "claims": {
          "peac_version": "0.2",
          "kind": "evidence",
          "type": "org.peacprotocol/payment",
          "iss": "https://api.example.com",
          "iat": 1709500000,
          "jti": "ext-valid-001",
          "pillars": ["commerce"],
          "extensions": {
            "org.peacprotocol/commerce": {
              "payment_rail": "stripe",
              "amount_minor": "1000",
              "currency": "USD"
            }
          }
        }
      },
      "expected": {
        "valid": true
      }
    },
    {
      "name": "commerce-negative-amount-valid",
      "description": "Negative amount_minor (refund) is permitted",
      "type": "full-pipeline",
      "primary_requirement_id": "WIRE02-EXT-009",
