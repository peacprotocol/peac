  "fixtures": [
    {
      "name": "reject-jwk",
      "description": "JWS header with embedded JWK must be rejected (JOSE hardening)",
      "type": "jws-security",
      "input": {
        "header_overrides": {
          "jwk": {
            "kty": "OKP",
            "crv": "Ed25519",
            "x": "abc123"
          }
        },
        "claims": {
          "peac_version": "0.2",
          "kind": "evidence",
          "type": "org.peacprotocol/payment",
          "iss": "https://api.example.com",
          "iat": 1709500000,
          "jti": "wire02-invalid-001"
        }
      },
      "expected": {
        "valid": false,
        "error_code": "E_JWS_EMBEDDED_KEY"
      }
    },
    {
      "name": "reject-x5c",
