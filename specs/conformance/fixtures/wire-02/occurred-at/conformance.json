        "claims": {
          "peac_version": "0.2",
          "kind": "evidence",
          "type": "org.peacprotocol/payment",
          "iss": "https://api.example.com",
          "iat": 1709500300,
          "jti": "occ-valid-003",
          "occurred_at": "2024-03-03T23:53:20Z"
        }
      },
      "expected": {
        "valid": true
