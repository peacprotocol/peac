      "primary_requirement_id": "WIRE02-OCC-001",
      "requirement_ids": ["WIRE02-OCC-001"],
      "status": "positive",
      "input": {
        "claims": {
          "peac_version": "0.2",
          "kind": "evidence",
          "type": "org.peacprotocol/payment",
          "iss": "https://api.example.com",
          "iat": 1709500000,
