{
  "$schema": "../vector.schema.json",
  "id": "x402-consistency-resource-mismatch",
  "kind": "consistency_verification",
  "description": "Receipt resourceUrl does not match offer resourceUrl",
  "category": "consistency",
  "input": {
    "offerPayload": {
      "version": 1,
      "resourceUrl": "https://api.example.com/weather/london",
      "scheme": "exact",
      "network": "eip155:8453",
      "asset": "USDC",
      "amount": "100000",
      "payTo": "0x742d35Cc6634C0532925a3b844Bc9e7595f1e123",
      "validUntil": 9999999999
    },
    "receiptPayload": {
      "version": 1,
      "network": "eip155:8453",
      "resourceUrl": "https://api.example.com/weather/paris",
      "payer": "0xabc1234567890abcdef1234567890abcdef123456",
      "issuedAt": 1741900000
    }
  },
  "expected": {
    "valid": false,
    "errors": [
      {
        "code": "receipt_resource_mismatch"
      }
    ]
  },
  "notes": "Offer is for /weather/london but receipt claims /weather/paris. Resource binding mismatch must be rejected."
}
