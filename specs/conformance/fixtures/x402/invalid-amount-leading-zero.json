{
  "$schema": "../vector.schema.json",
  "id": "x402-invalid-amount-leading-zero",
  "kind": "offer_verification",
  "description": "Amount with leading zeros must fail amount validation",
  "category": "invalid",
  "input": {
    "offer": {
      "payload": {
        "version": 1,
        "validUntil": 9999999999,
        "network": "eip155:8453",
        "asset": "USDC",
        "amount": "0100000",
        "payTo": "0x742d35Cc6634C0532925a3b844Bc9e7595f1e123",
        "resourceUrl": "https://fixture.example.com/resource",
        "scheme": "exact"
      },
      "signature": "0xababababababababababababababababababababababababababababababababcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcd1b",
      "format": "eip712",
      "acceptIndex": 0
    },
    "accepts": [
      {
        "network": "eip155:8453",
        "asset": "USDC",
        "payTo": "0x742d35Cc6634C0532925a3b844Bc9e7595f1e123",
        "amount": "100000",
        "scheme": "exact"
      }
    ]
  },
  "expected": {
    "valid": false,
    "errors": [
      {
        "code": "amount_invalid",
        "field": "payload.amount"
      }
    ]
  },
  "notes": "Leading zeros are not allowed (except for the value '0' itself). Amount '0100000' should fail."
}
