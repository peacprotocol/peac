{
  "$schema": "../vector.schema.json",
  "id": "x402-eip712-no-expiry",
  "kind": "offer_verification",
  "description": "EIP-712 placeholder: validUntil 0 means no expiry; accepted with allow_missing policy",
  "category": "edge-cases",
  "input": {
    "offer": {
      "payload": {
        "version": 1,
        "validUntil": 0,
        "network": "eip155:8453",
        "asset": "USDC",
        "amount": "100000",
        "payTo": "0x742d35Cc6634C0532925a3b844Bc9e7595f1e123",
        "resourceUrl": "https://fixture.example.com/resource",
        "scheme": "exact"
      },
      "signature": "0xababababababababababababababababababababababababababababababababcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcd1b",
      "format": "eip712",
      "acceptIndex": 0
    },
    "accepts": [
      {
        "network": "eip155:8453",
        "asset": "USDC",
        "payTo": "0x742d35Cc6634C0532925a3b844Bc9e7595f1e123",
        "amount": "100000",
        "scheme": "exact"
      }
    ]
  },
  "config": {
    "offerExpiryPolicy": "allow_missing"
  },
  "expected": {
    "valid": true,
    "matchedIndex": 0,
    "usedHint": true,
    "errors": []
  },
  "notes": "EIP-712 uses validUntil: 0 as a placeholder meaning 'no expiry' (fixed schema requires the field). With offerExpiryPolicy 'allow_missing', this is accepted. Layer B normalization converts 0 to semantic absence."
}
