{
  "$schema": "../vector.schema.json",
  "id": "x402-eip712-no-expiry-rejected",
  "kind": "offer_verification",
  "description": "EIP-712 placeholder: validUntil 0 rejected when offerExpiryPolicy is 'require'",
  "category": "invalid",
  "input": {
    "offer": {
      "payload": {
        "version": 1,
        "validUntil": 0,
        "network": "eip155:8453",
        "asset": "USDC",
        "amount": "100000",
        "payTo": "0x742d35Cc6634C0532925a3b844Bc9e7595f1e123",
        "resourceUrl": "https://fixture.example.com/resource",
        "scheme": "exact"
      },
      "signature": "0xababababababababababababababababababababababababababababababababcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcdcd1b",
      "format": "eip712",
      "acceptIndex": 0
    },
    "accepts": [
      {
        "network": "eip155:8453",
        "asset": "USDC",
        "payTo": "0x742d35Cc6634C0532925a3b844Bc9e7595f1e123",
        "amount": "100000",
        "scheme": "exact"
      }
    ]
  },
  "config": {
    "offerExpiryPolicy": "require"
  },
  "expected": {
    "valid": false,
    "errors": [
      {
        "code": "offer_no_expiry",
        "field": "payload.validUntil"
      }
    ]
  },
  "notes": "EIP-712 validUntil: 0 is the 'no expiry' placeholder. With offerExpiryPolicy 'require', PEAC rejects offers without expiry (unbounded replay window). This is a deliberate PEAC strictness policy."
}
