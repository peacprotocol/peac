{
  "family": "ijson-raw-input",
  "description": "Raw-bytes I-JSON (RFC 7493) rejection/acceptance vectors proving the TypeScript and Go reference gates reach the same decision before JSON parsing. Inputs are base64url of the raw JSON document bytes.",
  "version": "0.16.0",
  "status": "Informative",
  "vectors": [
    {
      "id": "duplicate-member-name-payload",
      "description": "two members named \"a\" in the same object",
      "input_b64": "eyJhIjoxLCJhIjoyfQ",
      "expected": {
        "accepted": false,
        "code": "E_IJSON_DUPLICATE_MEMBER_NAME"
      }
    },
    {
      "id": "duplicate-member-name-nested",
      "description": "duplicate member name inside a nested object",
      "input_b64": "eyJ4Ijp7ImEiOjEsImEiOjJ9fQ",
      "expected": {
        "accepted": false,
        "code": "E_IJSON_DUPLICATE_MEMBER_NAME"
      }
    },
    {
      "id": "duplicate-member-name-header",
      "description": "duplicate \"alg\" in a JWS-header-shaped object",
      "input_b64": "eyJhbGciOiJFZERTQSIsImFsZyI6Im5vbmUiLCJ0eXAiOiJpbnRlcmFjdGlvbi1yZWNvcmQrand0Iiwia2lkIjoiayJ9",
      "expected": {
        "accepted": false,
        "code": "E_IJSON_DUPLICATE_MEMBER_NAME"
      }
    },
    {
      "id": "duplicate-member-name-escaped-equivalent",
      "description": "member names equal only AFTER escape processing (\"a\\/b\" decodes to \"a/b\"); proves duplicate detection is post-unescape, not raw-substring",
      "input_b64": "eyJhXC9iIjoxLCJhL2IiOjJ9",
      "expected": {
        "accepted": false,
        "code": "E_IJSON_DUPLICATE_MEMBER_NAME"
      }
    },
    {
