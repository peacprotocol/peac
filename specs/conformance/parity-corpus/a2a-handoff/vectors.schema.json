{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peacprotocol.org/specs/conformance/parity-corpus/a2a-handoff/vectors.schema.json",
  "title": "A2A handoff parity corpus vectors",
  "description": "Schema for v0.14.1 A2A handoff observation parity vectors. Covers the 10 type URIs of org.peacprotocol/a2a-handoff (Agent Card observation + 9 task / human lifecycle events) plus at least 5 negative vectors covering digest-only card_ref violations, decision-vocabulary rejections, legacy signature shape rejection, type/event mismatches, and opaque-ref grammar violations.",
  "type": "object",
  "additionalProperties": false,
  "required": ["family", "description", "version", "vectors"],
  "properties": {
    "family": { "const": "a2a-handoff" },
    "description": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generator": { "type": "string" },
    "vectors": {
      "type": "array",
      "minItems": 15,
      "items": { "$ref": "#/$defs/vector" }
    }
  },
  "$defs": {
    "vector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "input", "expected"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$", "minLength": 1, "maxLength": 64 },
        "description": { "type": "string", "minLength": 1, "maxLength": 512 },
        "input": { "$ref": "#/$defs/input" },
        "expected": { "$ref": "#/$defs/expected" }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["payload"],
      "properties": {
        "payload": { "type": "object" },
        "header": { "type": "object" }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accepted"],
      "properties": {
        "accepted": { "type": "boolean" },
        "errors": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code"],
      "properties": {
        "code": { "type": "string", "minLength": 1, "maxLength": 128 },
        "path": { "type": "string", "maxLength": 256 }
      }
    }
  }
}
