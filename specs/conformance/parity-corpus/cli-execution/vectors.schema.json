{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peacprotocol.org/specs/conformance/parity-corpus/cli-execution/vectors.schema.json",
  "title": "CLI execution parity corpus vectors",
  "description": "Schema for CLI execution observation parity vectors. Positive-only deterministic JSON observation payloads pinning the canonical CLI execution observation shapes that conformance MUST accept. Every vector here is internally valid against CliExecutionSchema; semantic-rejection cases live in the schema validator tests at packages/schema/__tests__/extensions/cli-execution.test.ts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["family", "description", "version", "vectors"],
  "properties": {
    "family": { "const": "cli-execution" },
    "description": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generator": { "type": "string" },
    "vectors": {
      "type": "array",
      "minItems": 6,
      "items": { "$ref": "#/$defs/vector" }
    }
  },
  "$defs": {
    "vector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "input", "expected"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$", "minLength": 1, "maxLength": 64 },
        "description": { "type": "string", "minLength": 1, "maxLength": 512 },
        "input": { "$ref": "#/$defs/input" },
        "expected": { "$ref": "#/$defs/expected" }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["payload"],
      "properties": {
        "payload": { "type": "object" },
        "header": { "type": "object" }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accepted"],
      "properties": {
        "accepted": { "type": "boolean" },
        "errors": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code"],
      "properties": {
        "code": { "type": "string", "minLength": 1, "maxLength": 128 },
        "path": { "type": "string", "maxLength": 256 }
      }
    }
  }
}
