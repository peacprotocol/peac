#!/usr/bin/env bash
# .githooks/pre-commit
# Repo-managed pre-commit hook: format staged files, check for planning leaks.
# Install: git config core.hooksPath .githooks
# Or run: bash scripts/setup-hooks.sh

set -euo pipefail

echo "[pre-commit] Running staged file checks..."

# Format staged files with Prettier (fix in place, re-stage)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|json|md|yml|yaml)$' || true)

if [ -n "$STAGED_FILES" ]; then
  echo "[pre-commit] Formatting staged files..."
  echo "$STAGED_FILES" | xargs pnpm exec prettier --write --ignore-unknown 2>/dev/null || true
  echo "$STAGED_FILES" | xargs git add
fi

# Check for planning leak in staged content
echo "[pre-commit] Checking for planning leaks..."
bash scripts/check-planning-leak.sh

echo "[pre-commit] OK"
