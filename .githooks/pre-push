#!/usr/bin/env bash
# .githooks/pre-push
# Repo-managed pre-push hook: full CI-parity gate via scripts/gate.sh.
# Install: bash scripts/setup-hooks.sh
#
# This hook calls the SAME gate script that CI runs. If it passes here,
# CI will pass (modulo platform differences like Windows audit).
#
# Bypass: PEAC_SKIP_PRE_PUSH=1 git push
# A bypass requires the env var AND logs a visible warning.
# Treat bypass as exceptional; document the reason in your commit or PR.

set -euo pipefail

if [ "${PEAC_SKIP_PRE_PUSH:-}" = "1" ]; then
  echo "[pre-push] BYPASSED (PEAC_SKIP_PRE_PUSH=1)"
  echo "[pre-push] WARNING: You are pushing without running quality gates."
  echo "[pre-push] CI will still run all checks. If CI fails, you will need to fix and force-push."
  exit 0
fi

echo "[pre-push] Running full gate (CI parity)..."
echo "[pre-push] This may take a few minutes. To skip: PEAC_SKIP_PRE_PUSH=1 git push"
echo ""

bash scripts/gate.sh

echo ""
echo "[pre-push] All gates passed. Push proceeding."
