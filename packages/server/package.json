{
  "name": "@peac/server",
  "version": "0.16.0",
  "private": true,
  "description": "PEAC verification server with DoS protection and rate limiting",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "peac-server": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peacprotocol/peac.git",
    "directory": "packages/server"
  },
  "author": "PEAC Protocol Contributors",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/peacprotocol/peac/issues"
  },
  "homepage": "https://github.com/peacprotocol/peac#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@peac/protocol": "workspace:*",
    "@peac/schema": "workspace:*",
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "peac",
    "peacprotocol",
    "interaction-records",
    "signed-records",
    "receipts",
    "originary",
    "server",
    "api",
    "verification",
    "http"
  ]
}
