{
  "name": "@peac/mappings-ucp",
  "version": "0.15.0",
  "description": "Google Universal Commerce Protocol (UCP) mapping to PEAC receipts and dispute evidence",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "peac",
    "peacprotocol",
    "interaction-records",
    "signed-records",
    "receipts",
    "originary",
    "ucp",
    "universal-commerce",
    "order-management",
    "payment-evidence"
  ],
  "author": "PEAC Protocol Contributors",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/peacprotocol/peac/issues"
  },
  "homepage": "https://github.com/peacprotocol/peac#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peacprotocol/peac.git",
    "directory": "packages/mappings/ucp"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@peac/adapter-core": "workspace:*",
    "@peac/kernel": "workspace:*",
    "@peac/schema": "workspace:*",
    "jose": "^5.2.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
