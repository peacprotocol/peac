{
  "name": "@peac/policy-kit",
  "version": "0.12.11",
  "description": "PEAC Policy Kit - deterministic policy evaluation for CAL semantics",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peacprotocol/peac.git",
    "directory": "packages/policy-kit"
  },
  "author": "PEAC Protocol Contributors",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/peacprotocol/peac/issues"
  },
  "homepage": "https://github.com/peacprotocol/peac#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate:profiles": "tsx scripts/generate-profiles.ts",
    "generate:profiles:check": "tsx scripts/generate-profiles.ts --check",
    "prebuild": "rm -rf dist",
    "build": "pnpm generate:profiles && pnpm run build:js && pnpm run build:types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "tsx scripts/tarball-smoke-test.ts",
    "clean": "rm -rf dist",
    "build:js": "tsup",
    "build:types": "rm -f dist/.tsbuildinfo && tsc && rm -f dist/.tsbuildinfo"
  },
  "dependencies": {
    "@peac/schema": "workspace:*",
    "yaml": "^2.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.0",
    "tsup": "^8.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "peac",
    "peacprotocol",
    "interaction-records",
    "signed-records",
    "receipts",
    "originary",
    "policy",
    "discovery",
    "well-known",
    "peac-txt",
    "issuer-config"
  ]
}
