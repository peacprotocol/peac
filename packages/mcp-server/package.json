{
  "name": "@peac/mcp-server",
  "version": "0.11.3",
  "description": "PEAC receipt operations as MCP tools (verify, inspect, decode, issue, bundle)",
  "mcpName": "io.github.peacprotocol/peac",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "bin": {
    "peac-mcp-server": "./dist/cli.cjs"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/peacprotocol/peac.git",
    "directory": "packages/mcp-server"
  },
  "author": "jithinraj <7850727+jithinraj@users.noreply.github.com>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/peacprotocol/peac/issues"
  },
  "homepage": "https://github.com/peacprotocol/peac#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "server.json",
    "smithery.yaml",
    "manifest.json",
    ".mcp.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "pnpm run build:js && pnpm run build:types",
    "test": "pnpm -w vitest run packages/mcp-server/tests",
    "test:watch": "pnpm -w vitest packages/mcp-server/tests",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "build:js": "node scripts/build-js.mjs",
    "build:types": "rm -f dist/.tsbuildinfo && tsc && rm -f dist/.tsbuildinfo"
  },
  "dependencies": {
    "@peac/crypto": "workspace:*",
    "@peac/kernel": "workspace:*",
    "@peac/protocol": "workspace:*",
    "@peac/schema": "workspace:*",
    "@modelcontextprotocol/sdk": "~1.27.0",
    "commander": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.0",
    "tsup": "^8.0.0"
  }
}
