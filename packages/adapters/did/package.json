{
  "name": "@peac/adapter-did",
  "version": "0.12.11",
  "description": "DID document resolution for PEAC receipt verification (did:key, did:web)",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peacprotocol/peac.git",
    "directory": "packages/adapters/did"
  },
  "author": "PEAC Protocol Contributors",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:js": "tsup",
    "build:types": "tsc --emitDeclarationOnly --declaration",
    "build": "pnpm build:js && pnpm build:types",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@peac/kernel": "workspace:*",
    "@peac/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.0"
  },
  "bugs": {
    "url": "https://github.com/peacprotocol/peac/issues"
  },
  "homepage": "https://github.com/peacprotocol/peac#readme",
  "keywords": [
    "peac",
    "peacprotocol",
    "interaction-records",
    "signed-records",
    "receipts",
    "originary",
    "adapter-did",
    "did",
    "did-key",
    "did-web",
    "decentralized-identity",
    "w3c-did-core",
    "ed25519",
    "verification"
  ]
}
