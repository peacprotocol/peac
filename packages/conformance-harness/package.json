{
  "name": "@peac/conformance-harness",
  "version": "0.12.13",
  "private": true,
  "description": "Conformance test harness for PEAC protocol fixtures",
  "main": "dist/index.cjs",
  "bin": {
    "conformance-harness": "./dist/cli.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peacprotocol/peac.git",
    "directory": "packages/conformance-harness"
  },
  "author": "PEAC Protocol Contributors",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "pnpm run build:js",
    "build:js": "tsup",
    "clean": "rm -rf dist",
    "conformance": "tsx src/cli.ts"
  },
  "dependencies": {
    "@peac/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "bugs": {
    "url": "https://github.com/peacprotocol/peac/issues"
  },
  "homepage": "https://github.com/peacprotocol/peac#readme",
  "keywords": [
    "peac",
    "peacprotocol",
    "interaction-records",
    "signed-records",
    "receipts",
    "originary",
    "conformance",
    "test-vectors",
    "fixtures",
    "compliance-testing"
  ]
}
