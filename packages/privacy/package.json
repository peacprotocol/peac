    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "typescript": "^5.3.3",
    "vitest": "^4.0.0"
  },
  "sideEffects": false,
  "bugs": {
    "url": "https://github.com/peacprotocol/peac/issues"
  },
  "homepage": "https://github.com/peacprotocol/peac#readme",
