{
  "name": "@peac/privacy",
  "version": "0.13.1",
  "private": true,
  "description": "Privacy pillar for PEAC protocol - k-anonymity, privacy-preserving hashing, data protection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peacprotocol/peac.git",
    "directory": "packages/privacy"
  },
  "author": "PEAC Protocol Contributors",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
