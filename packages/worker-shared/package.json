      "default": "./src/index.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/peacprotocol/peac.git",
    "directory": "packages/worker-shared"
  },
  "author": "PEAC Protocol Contributors",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc --noEmit",
