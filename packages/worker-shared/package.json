{
  "name": "@peac/worker-shared",
  "version": "0.14.4",
  "private": true,
  "description": "Shared runtime-neutral TAP verification logic for edge worker surfaces",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peacprotocol/peac.git",
    "directory": "packages/worker-shared"
  },
  "author": "PEAC Protocol Contributors",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"/* no-op: source-exports package has no build artifacts */\""
  },
  "dependencies": {
    "@peac/contracts": "workspace:*",
    "@peac/mappings-tap": "workspace:*"
  },
  "sideEffects": false,
  "bugs": {
    "url": "https://github.com/peacprotocol/peac/issues"
  },
  "homepage": "https://github.com/peacprotocol/peac#readme",
  "keywords": [
    "peac",
    "peacprotocol",
    "interaction-records",
    "signed-records",
    "receipts",
    "originary",
    "worker",
    "edge",
    "shared",
    "utilities"
  ]
}
