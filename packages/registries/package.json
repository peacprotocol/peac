{
  "name": "@peac/registries",
  "version": "0.13.3",
  "private": true,
  "description": "PEAC Protocol - workspace-private internal facade re-grouping public @peac/kernel constants for internal-consumer ergonomics. Not published. Version tracks the workspace-wide value enforced by scripts/check-version-coherence.sh; the workspace-wide bump to 0.13.1 happens in the v0.13.1 release-prep PR.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./verifier-context": {
      "types": "./dist/verifier-context.d.ts",
      "import": "./dist/verifier-context.mjs",
      "require": "./dist/verifier-context.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.mjs",
      "require": "./dist/adapters.cjs"
    },
    "./extensions": {
      "types": "./dist/extensions.d.ts",
      "import": "./dist/extensions.mjs",
      "require": "./dist/extensions.cjs"
    },
    "./proofs-and-receipts": {
      "types": "./dist/proofs-and-receipts.d.ts",
      "import": "./dist/proofs-and-receipts.mjs",
      "require": "./dist/proofs-and-receipts.cjs"
    }
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "pnpm run build:js && pnpm run build:types",
    "build:js": "tsup",
    "build:types": "rm -f dist/.tsbuildinfo && tsc && rm -f dist/.tsbuildinfo",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@peac/kernel": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
