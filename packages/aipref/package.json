{
  "name": "@peac/pref",
  "version": "0.12.13",
  "description": "Deprecated facade over @peac/mappings-content-signals (AIPREF / robots.txt / tdmrep). Use @peac/mappings-content-signals directly.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test src/*.test.js",
    "lint": "echo 'Lint temporarily disabled due to workspace dependencies - run from root'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@peac/crypto": "workspace:*",
    "@peac/mappings-content-signals": "workspace:*",
    "@peac/policy-kit": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "peac",
    "peacprotocol",
    "interaction-records",
    "signed-records",
    "receipts",
    "originary",
    "aipref",
    "preferences",
    "robots",
    "content-usage"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peacprotocol/peac.git",
    "directory": "packages/aipref"
  },
  "bugs": {
    "url": "https://github.com/peacprotocol/peac/issues"
  },
  "homepage": "https://github.com/peacprotocol/peac#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "author": "PEAC Protocol Contributors"
}
