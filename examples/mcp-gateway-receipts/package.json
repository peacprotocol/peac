{
  "name": "@peac/example-mcp-gateway-receipts",
  "version": "0.0.0",
  "private": true,
  "description": "PEAC gateway example: signed records for gateway-mediated MCP tool calls, with policy decisions, content digests, and offline verification",
  "type": "module",
  "scripts": {
    "demo": "tsx demo.ts",
    "demo:tamper": "tsx demo.ts --tamper",
    "demo:show-record": "tsx demo.ts --show-record",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@peac/crypto": "workspace:*",
    "@peac/mappings-mcp": "workspace:*",
    "@peac/protocol": "workspace:*",
    "@peac/schema": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
