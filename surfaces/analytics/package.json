{
  "name": "@peac/analytics",
  "version": "0.14.3",
  "private": true,
  "description": "Analytics surface for PEAC Protocol - metrics API with k-anonymity protection",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@peac/privacy": "workspace:*",
    "@peac/kernel": "workspace:*",
    "@peac/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "typescript": "^5.3.3",
    "vitest": "^4.0.0"
  },
  "sideEffects": false,
  "author": "PEAC Protocol Contributors",
  "bugs": {
    "url": "https://github.com/peacprotocol/peac/issues"
  },
  "homepage": "https://github.com/peacprotocol/peac#readme",
  "keywords": [
    "peac",
    "peacprotocol",
    "interaction-records",
    "signed-records",
    "receipts",
    "originary",
    "analytics",
    "telemetry",
    "dashboard",
    "metrics"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peacprotocol/peac.git",
    "directory": "surfaces/analytics"
  }
}
