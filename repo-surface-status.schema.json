{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peacprotocol.org/schemas/repo-surface-status.schema.json",
  "title": "PEAC Repository Surface Status",
  "description": "Machine-readable classification of every discoverable surface in the PEAC Protocol workspace.",
  "type": "object",
  "required": ["description", "version", "updated", "states", "surfaces"],
  "properties": {
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "states": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "surfaces": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["state"],
        "properties": {
          "npm": { "type": ["string", "null"] },
          "state": {
            "type": "string",
            "enum": [
              "default",
              "recommended",
              "supported",
              "compat-only",
              "deprecated",
              "archived",
              "experimental"
            ]
          },
          "wire": { "type": "string" },
          "layer": { "type": ["number", "string"] },
          "published": { "type": "boolean" },
          "removal": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
