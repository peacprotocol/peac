{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation-testing posture. Advisory at v0.13.0; not wired into CI. Run locally with `pnpm mutation:baseline` against the high-leverage layer-0/1/2/3 packages and review survivors in docs/baselines/MUTATION-BASELINE-v0.13.0.md. Promotion to a CI gate requires a recorded roadmap decision.",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "reporters": ["html", "clear-text", "json"],
  "coverageAnalysis": "perTest",
  "mutate": [
    "packages/kernel/src/**/*.ts",
    "packages/schema/src/**/*.ts",
    "packages/crypto/src/**/*.ts",
    "packages/protocol/src/**/*.ts",
    "packages/policy-kit/src/**/*.ts",
    "!packages/**/src/**/*.generated.ts",
    "!packages/**/src/**/*.d.ts",
    "!packages/**/src/**/*.test.ts",
    "!packages/**/src/**/__tests__/**"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 0
  },
  "timeoutMS": 60000,
  "concurrency": 4,
  "ignoreStatic": true
}
